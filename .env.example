# =============================================================================
# polymarket_lp_tool — 环境变量示例
# =============================================================================
# 使用方式：复制为 .env 后填入真实值（勿将 .env 提交到 Git）
#   cp .env.example .env
#
# 完整 PASSIVE_* 列表与默认值见：passive_liquidity/config_manager.py → PassiveConfig.from_env()
# =============================================================================

# -----------------------------------------------------------------------------
# 必填：CLOB 交易身份（与 py-clob-client 一致）
# -----------------------------------------------------------------------------
# 钱包私钥（0x 开头十六进制）。也可用 POLYMARKET_PRIVATE_KEY，二者取一即可。
PRIVATE_KEY=

# 资金所在地址（邮箱/Magic/浏览器代理钱包时为 Proxy/Funder 地址）
POLYMARKET_FUNDER=

# -----------------------------------------------------------------------------
# 可选：CLOB / 链
# -----------------------------------------------------------------------------
# 0=EOA，1=Email/Magic，2=浏览器代理钱包
# POLYMARKET_SIGNATURE_TYPE=0

# POLYMARKET_HOST=https://clob.polymarket.com
# POLYMARKET_CHAIN_ID=137
# POLYMARKET_DATA_API=https://data-api.polymarket.com
# POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com

# -----------------------------------------------------------------------------
# 可选：Telegram 通知
# -----------------------------------------------------------------------------
# TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# 群组升级为「超级群」后 chat_id 会变；若 API 报 migrate_to_chat_id，请改用返回的新 ID
# TELEGRAM_CHAT_ID=
# TELEGRAM_ACCOUNT_LABEL=Polymarket账号1
# TELEGRAM_NOTIFY_COOLDOWN_SEC=30
# 群内 /status、/orders、/pnl 实时查询（长轮询独立线程；关闭则设 false）
# TELEGRAM_COMMANDS_ENABLED=true
# getUpdates 长轮询秒数（1–50，默认 25）
# TELEGRAM_COMMAND_POLL_TIMEOUT=25

# -----------------------------------------------------------------------------
# 可选：资金摘要 / 盈亏「入账参考」（优先级见 account_portfolio.resolve_deposit_reference）
# -----------------------------------------------------------------------------
# 手动指定累计入账基准（USDC），用于盈亏计算
# TELEGRAM_TOTAL_DEPOSITED_USDC=

# Polygonscan：链上 USDC 转入累计（需 API Key）
# POLYGONSCAN_API_KEY=
# POLYGON_USDC_CONTRACT=
# POLYGON_USDC_DEPOSIT_FROM_ALLOWLIST=
# POLYGONSCAN_TOKENTX_MAX_PAGES=25
# POLYGONSCAN_TOKENTX_OFFSET=1000

# Bridge API：Polygon 目标 USDC 合约列表（逗号分隔，一般不必改）
# BRIDGE_POLYGON_USDC_CONTRACTS=

# 仅当未配置链上/环境变量入账且仍要用「启动时账户总额」作参考时设为 true（不推荐）
# PASSIVE_USE_STARTUP_TOTAL_AS_DEPOSIT_REF=false

# -----------------------------------------------------------------------------
# 常用：主循环与白名单
# -----------------------------------------------------------------------------
# PASSIVE_LOOP_INTERVAL=2
# 逗号分隔 outcome token_id；留空则按未成交单维护白名单（见下一项）
# PASSIVE_TOKEN_WHITELIST=

# 未设置 PASSIVE_TOKEN_WHITELIST 时：每隔多少秒用当前未成交单重算白名单（默认 120 = 2 分钟）
# PASSIVE_WHITELIST_REFRESH_SEC=120
# 设为 0 则仅在启动时用当时未成交单种子，运行中不刷新

# PASSIVE_MONITORING_POST_ONLY=true
# PASSIVE_REPLACE_DELAY_AFTER_CANCEL_SEC=0
# PASSIVE_REPLACE_POST_RETRY_SEC=5
# PASSIVE_REPLACE_POST_MAX_RETRIES=0
# PASSIVE_MAX_API_ERRORS=0

# -----------------------------------------------------------------------------
# 可选：Telegram 成交流 / 周期摘要 / 被动监控告警（不影响下单逻辑）
# -----------------------------------------------------------------------------
# PASSIVE_TELEGRAM_NOTIFY_FILL=true
# PASSIVE_TELEGRAM_NOTIFY_PARTIAL_FILL=true
# PASSIVE_TELEGRAM_NOTIFY_FULL_FILL=true
# PASSIVE_TELEGRAM_BAND_SUMMARY=true
# PASSIVE_TELEGRAM_BAND_SUMMARY_SEC=600

# PASSIVE_ALERT_MONITORING=true
# PASSIVE_ALERT_COOLDOWN_SEC=120
# PASSIVE_ALERT_FILL_RATE_THRESHOLD=0.35
# PASSIVE_ALERT_SHORT_TRADES_THRESHOLD=8
# PASSIVE_ALERT_FILL_RISK_SCORE_THRESHOLD=0.45
# PASSIVE_ALERT_DIRECTION_IMBALANCE_MIN=0.62
# PASSIVE_ALERT_DEPTH_RATIO_THRESHOLD=0.15
# PASSIVE_MONITOR_SHORT_TRADE_LOOKBACK_SEC=180

# -----------------------------------------------------------------------------
# 可选：WebSocket 监控（更快成交通知与盘口/活动；撤单改价仍只走 REST 主循环）
# -----------------------------------------------------------------------------
# PASSIVE_WS_ENABLED=true
# PASSIVE_WS_USER_ENABLED=true
# PASSIVE_WS_MARKET_ENABLED=true
# 超过该秒数未收到对应行情更新则深度/活动回退 REST（用户成交仍可在连接时使用 WS 缓存）
# PASSIVE_WS_STALE_SEC=25
# 每 N 次主循环用 REST 未成交单校准用户 WS 仓位状态
# PASSIVE_WS_RECONCILE_LOOPS=15
# 用户/行情 WS 连接与断开时发 Telegram（受 TELEGRAM_ENABLED 与冷却影响）
# PASSIVE_WS_TELEGRAM_TRANSPORT=true
